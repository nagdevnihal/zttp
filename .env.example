# .env.example
# Copy to .env for local development: cp .env.example .env
# NEVER commit .env to version control.

# ── Proxy Server ────────────────────────────────────────────────────
PROXY_LISTEN_ADDR=0.0.0.0:2222
HTTP_LISTEN_ADDR=0.0.0.0:8080
GRPC_LISTEN_ADDR=0.0.0.0:9090
PROXY_NODE_IP=127.0.0.1

# ── TLS (Phase 5) ──────────────────────────────────────────────────
# TLS_CERT_FILE=/etc/zttp/tls/server.crt
# TLS_KEY_FILE=/etc/zttp/tls/server.key

# ── PostgreSQL ──────────────────────────────────────────────────────
DATABASE_URL=postgres://zttp:zttpsecret@localhost:5432/zttp?sslmode=disable
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10

# ── HashiCorp Vault ─────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8201
VAULT_TOKEN=dev-root-token-zttp          # Dev only — use AppRole in production
# VAULT_ROLE_ID=<from vault-seed.sh output>
# VAULT_SECRET_ID=<from vault-seed.sh output>

# ── Authentication Security ──────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION=15m
RATE_LIMIT_PER_MIN=10

# ── Audit Logging ───────────────────────────────────────────────────
AUDIT_LOG_DIR=/var/log/zttp/audit
AUDIT_DISK_MAX_PCT=95

# ── TCP Keepalive ───────────────────────────────────────────────────
KEEPALIVE_INTERVAL=30s
KEEPALIVE_MAX_MISS=3

# ── Integrations ───────────────────────────────────────────────────
SOC_WEBHOOK_URL=                          # Leave empty to disable SOC alerts in dev
